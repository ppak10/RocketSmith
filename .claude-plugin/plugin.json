{
  "name": "rocketsmith",
  "description": "Use agents to design and build high powered rockets",
  "version": "0.0.13",
  "author": {
    "name": "Peter Pak, Jesse Barkley, Rumi Loghmani"
  },
  "homepage": "https://github.com/ppak10/RocketSmith",
  "repository": "https://github.com/ppak10/RocketSmith",
  "license": "MIT",
  "keywords": ["rocketry", "openrocket", "prusaslicer", "simulation", "mcp"],
  "mcpServers": {
    "rocketsmith": {
      "command": "uv",
      "args": [
        "--directory",
        ".",
        "run",
        "-m",
        "rocketsmith.mcp"
      ],
      "env": {
        "PYTHONPATH": "./src",
        "ROCKETSMITH_PROJECT_DIR": "${workspacePath}"
      }
    }
  }
}
