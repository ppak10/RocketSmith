{
  "name": "rocketsmith",
  "description": "Use agents to design and build high powered rockets",
  "version": "0.0.11",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "rocketsmith": {
      "command": "uv",
      "args": ["run", "--directory", "${extensionPath}", "python", "-m", "rocketsmith.mcp"],
      "env": {
        "PYTHONPATH": "${extensionPath}/src"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "name": "rocketsmith-dep-check",
        "type": "command",
        "command": "uv run --directory ${extensionPath} rocketsmith setup check",
        "timeout": 10000
      }
    ]
  }
}
