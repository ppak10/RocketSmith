#!/bin/sh
# SessionEnd hook: stop any running GUI server(s).
# Reads .gui.pid from the working directory and sends SIGTERM to the
# entire process group. The servers are started with start_new_session=True,
# so the PID equals the PGID — killing the group ensures child processes
# (e.g., node under npx, asyncio tasks) are also terminated.
# The PID file may contain multiple PIDs (one per line) in dev mode.

PID_FILE="${PWD}/.gui.pid"

if [ -f "$PID_FILE" ]; then
    while IFS= read -r PID; do
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            # Kill the entire process group (PID == PGID due to start_new_session)
            kill -- -"$PID" 2>/dev/null || kill "$PID" 2>/dev/null
        fi
    done < "$PID_FILE"
    rm -f "$PID_FILE"
fi
